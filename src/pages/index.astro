---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Timeline from '../components/Timeline.astro';
import OfferCard from '../components/OfferCard.astro';
import CTA from '../components/CTA.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL, TUTORING_MAILTO } from '../consts';

const tutoringItems = [
	{
		title: '1v1课业辅导',
		tagline: '选课指导、课业规划、双语培优、作业辅导，一对一跟进',
		href: '/courses/tutoring',
		icon: 'compass' as const,
	},
	{
		title: '录播课程',
		tagline: '高微、高计、高宏、递归宏观、中级计量，五门系统课程',
		href: '/courses/recorded',
		icon: 'document' as const,
	},
	{
		title: '考前冲刺',
		tagline: 'GRE/GMAT定量、qualifying exam、技术面试摸底',
		href: '/courses/exam-prep',
		icon: 'chart' as const,
	},
];

const programItems = [
	{
		title: '陪跑',
		tagline: '跨阶段长期陪伴，适合起步早、需要持续节点把控的学生',
		href: '/programs/mentorship',
		icon: 'chart' as const,
	},
	{
		title: '咨询',
		tagline: '按小时付费的 office hours，适合有具体问题需要快速诊断',
		href: '/programs/consulting',
		icon: 'chat' as const,
	},
	{
		title: 'Predoc / PhD 申请规划',
		tagline: '从背景诊断到材料定制的完整申请规划服务',
		href: '/programs/predoc',
		icon: 'academic' as const,
	},
];

const tutoringSchools = ['芝加哥大学', '哥伦比亚大学', '约翰霍普金斯大学'];

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const offers = (await getCollection('offers')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const caseStudies = (await getCollection('case-studies'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

const homeFaqs = (await getCollection('faqs'))
	.filter((f) => f.data.showOnHome)
	.sort((a, b) => a.data.order - b.data.order)
	.map((f) => ({ question: f.data.question, answer: f.data.answer }));

const stats = [
	{ value: '200+', label: '团队月课时量' },
	{ value: '5+', label: '国家/地区高校学生分布（英美港新澳等）' },
	{ value: '10+', label: '讲师背景院校（芝加哥大学、东京大学、香港大学、北大、清华等）' },
	{ value: '全流程', label: '从课业辅导到学术生涯决策' },
];

const processSteps = [
	{ title: '背景诊断', description: '梳理 CV、成绩单、推荐信网络位置和技能栈，识别当前最强资产和最关键缺口。' },
	{ title: '路径与目标分层', description: '基于诊断结果给出路径建议，并将目标院校/岗位分为冲刺、合适、保底三档。' },
	{ title: '材料定制', description: '围绕研究主线重写 Cover Letter、CV、SOP，确保所有材料信号一致。' },
	{ title: '模拟面试与复盘', description: '在真实压力下暴露答题模式，识别红线回答并给出可执行的重构框架。' },
];

const professionalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	url: SITE_URL,
	areaServed: 'Global',
	knowsLanguage: ['zh-CN', 'en'],
};
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION} structuredData={professionalServiceSchema}>
	<Hero
		eyebrow="Best Studio"
		title="从课业提升到学术生涯决策，全周期支持"
		subtitle="我们覆盖本硕博阶段的课业辅导（1v1辅导、录播课程、考前冲刺）与学术生涯规划（陪跑、咨询、Predoc/PhD 申请规划），基于真实的教学与招募逻辑，帮助你在每个关键节点做出经得起验证的选择。"
		primaryCta={{ label: '联系我们', href: '/contact' }}
		secondaryCta={{ label: '查看全部服务', href: '/courses' }}
	/>

	<section class="mx-auto max-w-6xl px-6 pb-16">
		<div class="grid gap-8 border-y border-line py-10 sm:grid-cols-2 lg:grid-cols-4">
			{
				stats.map((stat) => (
					<div>
						<p class="text-2xl font-semibold text-ink">{stat.value}</p>
						<p class="mt-1 text-sm text-ink-soft">{stat.label}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<h2 class="text-2xl font-semibold text-ink md:text-3xl">六项业务，两条独立团队</h2>
		<p class="mt-3 max-w-2xl text-sm text-ink-soft">
			课业提升与学术生涯规划由两支独立团队负责，服务内容和联系方式分开管理。
		</p>

		<div class="mt-8">
			<p class="text-sm font-medium uppercase tracking-wide text-accent">课业提升 · 张博主讲</p>
			<div class="mt-4 grid gap-6 sm:grid-cols-3">
				{tutoringItems.map((item) => <ServiceCard {...item} />)}
			</div>
		</div>

		<div class="my-10 border-t border-line" />

		<div>
			<p class="text-sm font-medium uppercase tracking-wide text-accent">学术生涯规划</p>
			<div class="mt-4 grid gap-6 sm:grid-cols-3">
				{programItems.map((item) => <ServiceCard {...item} />)}
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<h2 class="text-2xl font-semibold text-ink md:text-3xl">课程辅导学生去向</h2>
		<p class="mt-3 max-w-2xl text-sm text-ink-soft">
			课程辅导学生（部分代表性院校，非完整名单）：
		</p>
		<div class="mt-6 flex flex-wrap gap-3">
			{
				tutoringSchools.map((school) => (
					<span class="rounded-full border border-line bg-paper px-4 py-2 text-sm text-ink-soft">{school}</span>
				))
			}
		</div>
		<a href={TUTORING_MAILTO} class="mt-6 inline-block text-sm font-medium text-accent hover:underline">
			联系课程辅导小助手 &rarr;
		</a>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<h2 class="text-2xl font-semibold text-ink md:text-3xl">我们能帮到谁</h2>
		<p class="mt-3 max-w-2xl text-sm text-ink-soft">以下聚焦学术生涯规划团队的服务对象——课程辅导详情见上方业务矩阵。</p>
		<div class="mt-8 grid gap-8 md:grid-cols-3">
			<div>
				<p class="text-sm font-medium uppercase tracking-wide text-accent">本科 / 硕士在读</p>
				<p class="mt-2 text-sm leading-relaxed text-ink-soft">
					研究经历分散、缺乏统一叙事，需要判断该优先积累资产还是准备申请材料。
				</p>
			</div>
			<div>
				<p class="text-sm font-medium uppercase tracking-wide text-accent">Predoc / RA 申请者</p>
				<p class="mt-2 text-sm leading-relaxed text-ink-soft">
					投递回复率低，需要诊断材料定制化程度，而不是继续增加投递量。
				</p>
			</div>
			<div>
				<p class="text-sm font-medium uppercase tracking-wide text-accent">PhD 申请者</p>
				<p class="mt-2 text-sm leading-relaxed text-ink-soft">
					需要在推荐信网络、研究经历真实程度与签证时间线之间做出有据可查的路径选择。
				</p>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="flex items-baseline justify-between">
			<h2 class="text-2xl font-semibold text-ink md:text-3xl">Predoc / PhD 申请规划服务详情</h2>
			<a href="/services" class="text-sm font-medium text-accent hover:underline">查看全部 &rarr;</a>
		</div>
		<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				services.map((service) => (
					<ServiceCard
						title={service.data.shortTitle}
						tagline={service.data.tagline}
						href={`/services/${service.id}`}
						icon={service.data.icon}
					/>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="flex items-baseline justify-between">
			<h2 class="text-2xl font-semibold text-ink md:text-3xl">Offer 墙</h2>
			<a href="/offers" class="text-sm font-medium text-accent hover:underline">查看全部 &rarr;</a>
		</div>
		<p class="mt-3 max-w-2xl text-sm text-ink-soft">
			以下为匿名化的复合场景，按背景类型分类展示，说明路径是否可复制，而不只是院校 logo 的堆砌。
		</p>
		<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{
				offers.map((offer) => (
					<OfferCard
						schoolTier={offer.data.schoolTier}
						backgroundTag={offer.data.backgroundTag}
						timeline={offer.data.timeline}
						insight={offer.data.insight}
						caseStudyHref={offer.data.caseStudySlug ? `/case-studies/${offer.data.caseStudySlug}` : undefined}
					/>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<h2 class="text-2xl font-semibold text-ink md:text-3xl">我们的流程</h2>
		<p class="mt-3 max-w-2xl text-sm text-ink-soft">
			咨询是一个多步骤的持续工作流，每一步的产出都是下一步的输入。
		</p>
		<div class="mt-10">
			<Timeline steps={processSteps} />
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="flex items-baseline justify-between">
			<h2 class="text-2xl font-semibold text-ink md:text-3xl">深度案例</h2>
			<a href="/case-studies" class="text-sm font-medium text-accent hover:underline">查看全部 &rarr;</a>
		</div>
		<p class="mt-3 max-w-2xl text-sm text-ink-soft">
			比 Offer 墙更完整的叙事版本：背景、问题、诊断、方案、结果的全过程拆解。
		</p>
		<div class="mt-8 grid gap-6 md:grid-cols-3">
			{
				caseStudies.map((study) => (
					<a
						href={`/case-studies/${study.id}`}
						class="group flex flex-col gap-3 rounded-2xl border border-line bg-paper p-6 transition-colors hover:border-accent"
					>
						<h3 class="text-base font-semibold text-ink">{study.data.title}</h3>
						<p class="text-sm leading-relaxed text-ink-soft">{study.data.summary}</p>
						<span class="mt-auto text-sm font-medium text-accent opacity-0 transition-opacity group-hover:opacity-100">
							阅读案例 &rarr;
						</span>
					</a>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-16">
		<h2 class="text-2xl font-semibold text-ink md:text-3xl">常见问题</h2>
		<div class="mt-8">
			<FaqAccordion items={homeFaqs} />
		</div>
	</section>

	<CTA
		heading="想清楚下一步该做什么？"
		body="先做一次背景诊断，通过微信公众号联系我们，会给你一个有据可查的路径建议。"
		buttonLabel="预约咨询"
		buttonHref="/book-a-call"
	/>
</Layout>
