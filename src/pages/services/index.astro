---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTA from '../../components/CTA.astro';
import { CONTACT_EMAIL } from '../../consts';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const title = '服务';
const description = '从 Predoc 申请到 PhD 申请、研究职业规划、简历诊断与面试教练，五项一对一辅导服务。';

const knowledgeProducts = [
	{
		title: 'Predoc 申请时间线 PDF',
		description: '北美 Predoc 岗位的发布规律、各阶段准备节点与签证时间线交叉约束图。',
		how: '邮件或微信公众号发送「时间线」免费获取',
		free: true,
	},
	{
		title: 'Predoc 面试题库（整理中）',
		description: '按技术追问类型分类的真实面试题合集，覆盖 Stata/R/Python 数据处理与统计判断。',
		how: '预计 2025 年底发布，关注公众号获取更新',
		free: false,
	},
];
---

<Layout title={title} description={description}>
	<section class="mx-auto max-w-3xl px-6 pb-12 pt-20 md:pt-28">
		<p class="text-sm font-medium uppercase tracking-wide text-accent">Services</p>
		<h1 class="mt-4 text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl">
			针对每个阶段的具体问题，而不是一份通用大纲
		</h1>
		<p class="mt-6 text-lg leading-relaxed text-ink-soft">
			你可以单独预约任意一项服务，也可以从背景诊断开始，由我们建议接下来最该优先解决的问题。
		</p>
	</section>

	<!-- 一对一辅导服务 -->
	<section class="mx-auto max-w-6xl px-6 pb-16">
		<h2 class="mb-6 text-xl font-semibold text-ink">一对一辅导</h2>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				services.map((service) => (
					<ServiceCard
						title={service.data.shortTitle}
						tagline={service.data.tagline}
						href={`/services/${service.id}`}
						icon={service.data.icon}
					/>
				))
			}
		</div>
	</section>

	<!-- 知识产品 -->
	<section class="mx-auto max-w-6xl px-6 pb-20">
		<div class="flex items-center gap-3">
			<h2 class="text-xl font-semibold text-ink">知识产品</h2>
			<span class="rounded-full bg-accent-soft px-3 py-0.5 text-xs font-medium text-accent">轻量入口</span>
		</div>
		<p class="mt-2 text-sm text-ink-soft">
			不需要立刻开始一对一咨询的同学，可以先从这里获取整理好的规划资源。
		</p>
		<div class="mt-6 grid gap-5 sm:grid-cols-2">
			{
				knowledgeProducts.map((product) => (
					<div class="rounded-2xl border border-line bg-paper p-7">
						<div class="flex items-start justify-between gap-3">
							<h3 class="text-base font-semibold text-ink">{product.title}</h3>
							{product.free && (
								<span class="shrink-0 rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-medium text-accent">
									免费
								</span>
							)}
						</div>
						<p class="mt-2 text-sm leading-relaxed text-ink-soft">{product.description}</p>
						<p class="mt-4 text-xs text-ink-soft">{product.how}</p>
						{product.free && (
							<a
								href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent('获取 Predoc 时间线 PDF')}&body=${encodeURIComponent('您好，我想获取 Predoc 申请时间线 PDF。\n\n我的情况：\n年级/专业：\n目标方向：\n')}`}
								class="mt-4 inline-block text-sm font-medium text-accent hover:underline"
							>
								邮件获取 &rarr;
							</a>
						)}
					</div>
				))
			}
		</div>
		<p class="mt-6 text-sm text-ink-soft">
			更多资源整理见 <a href="/resources" class="text-accent hover:underline">知识库</a>。
		</p>
	</section>

	<CTA
		heading="不确定该从哪一项开始？"
		body="预约一次背景诊断，我们会建议最适合你当前阶段的服务。"
		buttonLabel="预约咨询"
		buttonHref="/book-a-call"
	/>
</Layout>
