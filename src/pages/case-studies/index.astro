---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';

const caseStudies = (await getCollection('case-studies')).sort((a, b) => a.data.order - b.data.order);

const predocStudies = caseStudies.filter((s) => s.data.track === 'predoc');
const phdStudies = caseStudies.filter((s) => s.data.track === 'phd');

const title = '案例';
const description = '基于真实咨询模式整理的匿名化复合场景，说明典型问题的诊断与应对方式。';
---

<Layout title={title} description={description}>
	<section class="mx-auto max-w-3xl px-6 pb-8 pt-20 md:pt-28">
		<p class="text-sm font-medium uppercase tracking-wide text-accent">Case Studies</p>
		<h1 class="mt-4 text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl">
			真实的问题，抽象后的场景
		</h1>
		<p class="mt-6 text-lg leading-relaxed text-ink-soft">
			出于保密考虑，以下案例均为匿名化的复合场景——基于真实咨询中反复出现的问题模式整理而成，不对应任何具体个人。重点不是结果的"光鲜程度"，而是每个转折点背后的判断依据。
		</p>
	</section>

	<!-- Predoc 赛道 -->
	<section class="mx-auto max-w-6xl px-6 pb-8">
		<div class="flex items-center gap-3">
			<h2 class="text-xl font-semibold text-ink">Predoc / RA 赛道</h2>
			<span class="rounded-full bg-accent-soft px-3 py-0.5 text-xs font-medium text-accent">
				{predocStudies.length} 个案例
			</span>
		</div>
		<div class="mt-5 grid gap-6 md:grid-cols-2">
			{
				predocStudies.map((study) => (
					<a
						href={`/case-studies/${study.id}`}
						class="group flex flex-col gap-3 rounded-2xl border border-line bg-paper p-7 transition-colors hover:border-accent"
					>
						<h3 class="text-base font-semibold text-ink">{study.data.title}</h3>
						<p class="text-sm leading-relaxed text-ink-soft">{study.data.summary}</p>
						<span class="mt-auto text-sm font-medium text-accent opacity-0 transition-opacity group-hover:opacity-100">
							阅读案例 &rarr;
						</span>
					</a>
				))
			}
		</div>
	</section>

	<!-- PhD 赛道 -->
	{
		phdStudies.length > 0 && (
			<section class="mx-auto max-w-6xl px-6 py-8 pb-16">
				<div class="flex items-center gap-3">
					<h2 class="text-xl font-semibold text-ink">PhD 申请赛道</h2>
					<span class="rounded-full bg-accent-soft px-3 py-0.5 text-xs font-medium text-accent">
						{phdStudies.length} 个案例
					</span>
				</div>
				<div class="mt-5 grid gap-6 md:grid-cols-2">
					{phdStudies.map((study) => (
						<a
							href={`/case-studies/${study.id}`}
							class="group flex flex-col gap-3 rounded-2xl border border-line bg-paper p-7 transition-colors hover:border-accent"
						>
							<h3 class="text-base font-semibold text-ink">{study.data.title}</h3>
							<p class="text-sm leading-relaxed text-ink-soft">{study.data.summary}</p>
							<span class="mt-auto text-sm font-medium text-accent opacity-0 transition-opacity group-hover:opacity-100">
								阅读案例 &rarr;
							</span>
						</a>
					))}
				</div>
			</section>
		)
	}

	<!-- 与 Offer 墙的关联提示 -->
	<section class="mx-auto max-w-6xl px-6 pb-16">
		<div class="rounded-2xl border border-line bg-paper-raised p-7">
			<p class="text-sm font-medium text-ink">想看更简洁的结果摘要？</p>
			<p class="mt-2 text-sm text-ink-soft">
				Offer 墙按背景类型分类展示了更多匿名场景，每张卡片只呈现背景标签、时间线和一条核心洞察——适合快速浏览。
			</p>
			<a href="/offers" class="mt-4 inline-block text-sm font-medium text-accent hover:underline">
				前往 Offer 墙 &rarr;
			</a>
		</div>
	</section>

	<CTA
		heading="想知道你自己的情况适合哪条路径？"
		body="预约一次背景诊断，获得针对你具体情况的分析。"
		buttonLabel="预约咨询"
		buttonHref="/book-a-call"
	/>
</Layout>
