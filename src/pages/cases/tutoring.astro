---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import { TUTORING_MAILTO } from '../../consts';

const title = '课程辅导反馈';
const description = '来自 1v1课业辅导、录播课程学生的真实反馈。';

const placeholders = [1, 2, 3, 4];
---

<Layout title={title} description={description}>
	<section class="mx-auto max-w-3xl px-6 pb-12 pt-20 md:pt-28">
		<p class="text-sm font-medium uppercase tracking-wide text-accent">Cases · 课程辅导</p>
		<h1 class="mt-4 text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl">课程辅导反馈</h1>
		<p class="mt-6 text-lg leading-relaxed text-ink-soft">
			以下展示位用于呈现真实学生反馈（成绩单/评分截图等），当前待替换为真实素材。
		</p>
	</section>

	<section class="mx-auto max-w-5xl px-6 pb-20">
		<div class="grid gap-6 sm:grid-cols-2">
			{
				placeholders.map((i) => (
					<div class="flex aspect-[4/3] flex-col items-center justify-center gap-2 rounded-2xl border border-dashed border-line bg-paper-raised p-8 text-center">
						<p class="text-sm font-medium text-ink-soft">反馈截图 {i}</p>
						<p class="text-xs text-ink-soft">待替换为真实反馈截图</p>
					</div>
				))
			}
		</div>
	</section>

	<CTA
		heading="想了解具体的辅导效果？"
		body="联系课程辅导小助手，我们可以分享更多具体案例。"
		buttonLabel="联系课程辅导小助手"
		buttonHref={TUTORING_MAILTO}
	/>
</Layout>
