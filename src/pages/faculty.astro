---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { TUTORING_MAILTO, BILIBILI_URL } from '../consts';

const title = '师资力量';
const description = '课程辅导团队：芝加哥大学经济学相关博士背景的核心讲师张博，以及20余位覆盖多学科方向的讲师团队。';

const overseasSchools = [
	'芝加哥大学',
	'东京大学',
	'香港大学',
	'伦敦大学学院',
	'南安普顿大学',
	'威斯康星大学麦迪逊分校',
	'新加坡国立大学',
	'华盛顿大学',
];

const domesticSchools = ['北京大学', '清华大学', '复旦大学', '上海交通大学', '厦门大学', '中山大学', '对外经济贸易大学', '东南大学'];

const studentOutcomeSchools = [
	'芝加哥大学',
	'哥伦比亚大学',
	'约翰霍普金斯大学',
	'杜克大学',
	'帝国理工大学',
	'伦敦政治经济学院',
	'伦敦大学学院',
	'曼彻斯特大学',
	'爱丁堡大学',
];
---

<Layout title={title} description={description}>
	<section class="mx-auto max-w-3xl px-6 pb-12 pt-20 md:pt-28">
		<p class="text-sm font-medium uppercase tracking-wide text-accent">Faculty</p>
		<h1 class="mt-4 text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl">师资力量</h1>
		<p class="mt-6 text-lg leading-relaxed text-ink-soft">
			课程辅导团队由张博主讲，并配有覆盖不同课程方向的讲师团队。
		</p>
	</section>

	<section class="mx-auto max-w-3xl px-6 py-8">
		<div class="flex flex-col gap-6 rounded-2xl border border-line bg-paper p-8 sm:flex-row sm:items-start">
			<div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-accent-soft text-2xl font-semibold text-accent">
				张
			</div>
			<div>
				<h2 class="text-xl font-semibold text-ink">张博</h2>
				<p class="mt-1 text-sm font-medium uppercase tracking-wide text-accent">核心讲师</p>
				<p class="mt-3 text-sm leading-relaxed text-ink-soft">
					核心讲师，拥有横跨经济学、数学、统计学与计算机科学的多元学术背景，芝加哥大学经济学相关博士背景，本科阶段主修经济学与统计学并获最高荣誉学位，具备多语言学术阅读与表达能力。
				</p>
				<p class="mt-3 text-sm leading-relaxed text-ink-soft">
					1000+小时本硕博授课经验，200+小时录播课产出，教学内容覆盖经济学入门到博士资格考辅导，学生曾获{studentOutcomeSchools.join('、')}等院校课程通过与成绩提升。
				</p>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-3xl px-6 py-8">
		<h2 class="text-xl font-semibold text-ink">其他讲师团队</h2>
		<p class="mt-3 text-sm leading-relaxed text-ink-soft">
			团队现有讲师20余位，专业方向覆盖经济学、金融学、统计学、数学、会计学、市场营销学、数据科学，教育背景涵盖：
		</p>
		<div class="mt-5 space-y-4">
			<div>
				<p class="text-xs font-medium uppercase tracking-wide text-accent">海外院校</p>
				<div class="mt-2 flex flex-wrap gap-2">
					{
						overseasSchools.map((school) => (
							<span class="rounded-full border border-line bg-paper px-3 py-1.5 text-sm text-ink-soft">{school}</span>
						))
					}
				</div>
			</div>
			<div>
				<p class="text-xs font-medium uppercase tracking-wide text-accent">国内院校</p>
				<div class="mt-2 flex flex-wrap gap-2">
					{
						domesticSchools.map((school) => (
							<span class="rounded-full border border-line bg-paper px-3 py-1.5 text-sm text-ink-soft">{school}</span>
						))
					}
				</div>
			</div>
		</div>
		<p class="mt-4 text-sm leading-relaxed text-ink-soft">
			所有讲师均经过学历、试讲及学生评分三重审核，可提供授课demo供学生提前了解教学风格。
		</p>
	</section>

	{
		BILIBILI_URL && (
			<section class="mx-auto max-w-3xl px-6 py-8 pb-16">
				<a
					href={BILIBILI_URL}
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center justify-between gap-6 rounded-2xl border border-line bg-paper-raised p-7 transition-colors hover:border-accent"
				>
					<div>
						<p class="text-sm font-medium uppercase tracking-wide text-accent">B 站 · BestStudio留学辅导</p>
						<p class="mt-2 text-base text-ink">
							工作室官方视频号，收录多位讲师的课业辅导与案例拆解内容，覆盖经济、金融、统计等多个方向——不是某一位讲师的个人账号。
						</p>
					</div>
					<span class="shrink-0 text-sm font-medium text-accent">前往 B 站 &rarr;</span>
				</a>
			</section>
		)
	}

	<CTA
		heading="想预约张博或指定讲师的辅导？"
		body="联系课程辅导小助手，告诉我们你的课程需求。"
		buttonLabel="联系课程辅导小助手"
		buttonHref={TUTORING_MAILTO}
	/>
</Layout>
