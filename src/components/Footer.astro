---
import { CONTACT_EMAIL, FOOTER_LINKS, SITE_TAGLINE, SITE_TITLE, WECHAT_ACCOUNT, BILIBILI_URL } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-line/70 bg-paper-raised">
	<div class="mx-auto max-w-6xl px-6 py-14">
		<div class="grid gap-10 md:grid-cols-3">
			<div>
				<p class="text-lg font-semibold text-ink">{SITE_TITLE}</p>
				<p class="mt-2 max-w-xs text-sm text-ink-soft">{SITE_TAGLINE}</p>
			</div>

			<div>
				<p class="text-sm font-medium text-ink">导航</p>
				<ul class="mt-3 flex flex-col gap-2 text-sm text-ink-soft">
					{
						FOOTER_LINKS.map((link) => (
							<li>
								<a href={link.href} class="hover:text-ink">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<p class="text-sm font-medium text-ink">联系方式</p>
				<ul class="mt-3 flex flex-col gap-2 text-sm text-ink-soft">
					<li>
						<a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-ink">{CONTACT_EMAIL}</a>
					</li>
					<li>微信公众号：{WECHAT_ACCOUNT}</li>
					<li>
						<a href={BILIBILI_URL} target="_blank" rel="noopener noreferrer" class="hover:text-ink">
							B 站主页（BestStudio留学辅导）
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div
			class="mt-12 flex flex-col gap-3 border-t border-line/70 pt-6 text-xs text-ink-soft md:flex-row md:items-center md:justify-between"
		>
			<p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>
			<div class="flex gap-4">
				<a href="/privacy" class="hover:text-ink">隐私政策</a>
				<a href="/terms" class="hover:text-ink">服务条款</a>
			</div>
		</div>
	</div>
</footer>
