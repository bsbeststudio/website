---
interface Step {
	title: string;
	description: string;
}

interface Props {
	steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="relative flex flex-col gap-10 border-l border-line pl-8 md:grid md:grid-cols-2 md:gap-x-10 md:gap-y-12 md:border-l-0 md:pl-0">
	{
		steps.map((step, index) => (
			<li class="relative md:border-l md:border-line md:pl-8">
				<span class="absolute -left-[calc(2rem+1px)] top-1 flex h-6 w-6 items-center justify-center rounded-full bg-ink text-xs font-medium text-paper md:-left-[calc(2rem+1px)]">
					{index + 1}
				</span>
				<h3 class="text-base font-semibold text-ink">{step.title}</h3>
				<p class="mt-2 text-sm leading-relaxed text-ink-soft">{step.description}</p>
			</li>
		))
	}
</ol>
