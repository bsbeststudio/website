---
interface Props {
	heading: string;
	body: string;
	buttonLabel: string;
	buttonHref: string;
}

const { heading, body, buttonLabel, buttonHref } = Astro.props;
---

<section class="mx-auto max-w-6xl px-6 py-16">
	<div
		class="flex flex-col items-start gap-6 rounded-3xl bg-ink px-8 py-12 text-paper md:flex-row md:items-center md:justify-between md:px-14"
	>
		<div class="max-w-xl">
			<h2 class="text-2xl font-semibold md:text-3xl">{heading}</h2>
			<p class="mt-3 text-paper/80">{body}</p>
		</div>
		<a
			href={buttonHref}
			class="shrink-0 rounded-full bg-paper px-6 py-3 text-sm font-medium text-ink transition-colors hover:bg-accent hover:text-paper"
		>
			{buttonLabel}
		</a>
	</div>
</section>
